function UILibrary:Toggle()
self.Visible=not self.Visible
self.MainFrame.Visible=self.Visible
if self.ToggleBtn then
if self.Visible then
TweenService:Create(self.ToggleBtn,TweenInfo.new(0.2),{BackgroundColor3=THEME.Accent}):Play()
else
TweenService:Create(self.ToggleBtn,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(0,0,0)}):Play()
end
end
end
function UILibrary:Show()
self.Visible=true
self.MainFrame.Visible=true
end
function UILibrary:Hide()
self.Visible=false
self.MainFrame.Visible=false
end
function UILibrary:Destroy()
if self.Gui then
self.Gui:Destroy()
end
end
return UILibrary
