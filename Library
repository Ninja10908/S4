function UILibrary:AddTab(name)
local tab={}
tab.Name=name
tab.Buttons={}
tab.CurrentY=10
local tabButton=Instance.new('TextButton',self.LeftPanel)
tabButton.Size=UDim2.new(1,-12,0,38)
tabButton.Position=UDim2.new(0,6,0,8 + (#self.TabList * 42))
tabButton.BackgroundColor3=THEME.Button
tabButton.BorderSizePixel=0
tabButton.Text=name
tabButton.TextColor3=THEME.TextSecondary
tabButton.TextSize=13
tabButton.Font=Enum.Font.GothamMedium
tabButton.AutoButtonColor=false
tabButton.Name = "TabBtn_" .. name
local tabCor=Instance.new('UICorner',tabButton)
tabCor.CornerRadius=UDim.new(0,10)
local tabStr=Instance.new('UIStroke',tabButton)
tabStr.Name="TabStroke"
tabStr.Thickness=1
tabStr.Color=THEME.Stroke
tabStr.Transparency=0.6
local tabFrame=Instance.new('Frame',self.RightPanel)
tabFrame.Name=name .. "Content"
tabFrame.Size=UDim2.new(1,0,1,0)
tabFrame.Position=UDim2.new(0,0,0,0)
tabFrame.BackgroundTransparency=1
tabFrame.Visible=false
tab.Button=tabButton
tab.Frame=tabFrame
tab.Buttons={}
table.insert(self.TabList,tab)
self.TabFrames[name]=tab
if #self.TabList==1 then
self:SelectTab(name)
end
tabButton.MouseButton1Click:Connect(function()
self:SelectTab(name)
end)
tabButton.MouseEnter:Connect(function()
if self.CurrentTab ~=tab then
TweenService:Create(tabButton,TweenInfo.new(0.15),{BackgroundColor3=THEME.Hover}):Play()
end
end)
tabButton.MouseLeave:Connect(function()
if self.CurrentTab ~=tab then
TweenService:Create(tabButton,TweenInfo.new(0.15),{BackgroundColor3=THEME.Button}):Play()
end
end)
return tab
end
function UILibrary:SelectTab(name)
for _,tab in ipairs(self.TabList) do
if tab.Frame then
tab.Frame.Visible=false
end
if tab.Button then
tab.Button.BackgroundColor3=THEME.Button
tab.Button.TextColor3=THEME.TextSecondary
end
end
local selected=self.TabFrames[name]
if selected then
selected.Frame.Visible=true
selected.Button.BackgroundColor3=THEME.Active
selected.Button.TextColor3=THEME.Accent
self.CurrentTab=selected
end
end
